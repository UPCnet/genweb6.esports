<?xml version="1.0"?>
<registry>

  <records interface="Products.CMFPlone.interfaces.IBundleRegistry" prefix="plone.bundles/esports-bundle">

    <value key="enabled">True</value>
    <value key="compile">True</value>
    <value key="resources">
      <element>esports-main</element>
    </value>
    <value key="jscompilation" />
    <value key="csscompilation">++theme++genweb6.esports/stylesheets/theme-esports.min.css</value>

  </records>

   <records name="plone.app.querystring.field.fecini" interface="plone.app.querystring.interfaces.IQueryField" prefix="plone.app.querystring.field.fecini">
        <value key="title">Data Inici d'Activitat</value>
        <value key="description">Custom start date index</value>
        <value key="enabled">False</value>
        <value key="sortable">True</value>
        <value key="operations">
            <element>plone.app.querystring.operation.date.range</element>
        </value>
        <value key="group">Custom</value>
    </records>

  <!-- folder_contents (pat-structure): plone.icon.contenttype mas portal type normalizado -->
  <record name="plone.icon.contenttype/competicio">
    <field type="plone.registry.field.TextLine">
      <title>Esports competició</title>
    </field>
    <value key="resource">++plone++bootstrap-icons/calendar-event.svg</value>
  </record>
  <record name="plone.icon.contenttype/curs">
    <field type="plone.registry.field.TextLine">
      <title>Esports activitat (curs)</title>
    </field>
    <value key="resource">++plone++bootstrap-icons/file-earmark-text.svg</value>
  </record>
  <record name="plone.icon.contenttype/instalacio">
    <field type="plone.registry.field.TextLine">
      <title>Esports instal·lació</title>
    </field>
    <value key="resource">++plone++bootstrap-icons/building.svg</value>
  </record>
  <record name="plone.icon.contenttype/syncfolder">
    <field type="plone.registry.field.TextLine">
      <title>Esports sync folder</title>
    </field>
    <value key="resource">++plone++bootstrap-icons/arrow-clockwise.svg</value>
  </record>

</registry>
